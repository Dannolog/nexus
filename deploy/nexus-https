server {
    listen 3052 ssl;
    listen [::]:3052 ssl;
    http2 on;
    server_name 192.168.1.10 100.118.76.36 claude-code.fritz.box claude-code localhost;

    ssl_certificate     /etc/nginx/certs/vision.crt;
    ssl_certificate_key /etc/nginx/certs/vision.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    client_max_body_size 100m;
    error_page 497 =301 https://$host:3052$request_uri;
    proxy_buffering off;

    location / {
        proxy_pass http://127.0.0.1:3050;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300;
    }
}
