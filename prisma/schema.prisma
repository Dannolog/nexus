// Nexus — zentrale Stammdaten (KONZEPT.md §3.3)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Mandant (eigene Firma) ----
model Organization {
  id        String  @id @default(cuid())
  name      String
  shortCode String  @default("")
  street    String  @default("")
  zip       String  @default("")
  city      String  @default("")
  country   String  @default("Deutschland")
  taxNumber String  @default("")
  ustId     String  @default("")
  logo      String  @default("") @db.Text  // Mandanten-Logo/-symbol (base64 data URL), asynchron geladen
  version   Int      @default(1)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  numbers   CustomerNumber[]
}

// ---- Kunde (Superset kontor.Client + clocker.Client) ----
model Customer {
  id          String  @id @default(cuid())
  companyName String  @default("")
  contactName String  @default("")
  salutation  String  @default("")
  shortCode   String  @default("")
  color       String  @default("#3b82f6")
  street      String  @default("")
  zip         String  @default("")
  city        String  @default("")
  country     String  @default("Deutschland")
  addressFree String  @default("")
  email       String  @default("")
  phone       String  @default("")
  taxNumber   String  @default("")
  ustId       String  @default("")
  distanceKm  Float   @default(0)
  notes       String  @default("")
  logo        String  @default("") @db.Text  // Firmenlogo/-symbol (base64 data URL), asynchron geladen
  contacts    CustomerContact[]
  numbers     CustomerNumber[]
  projects    Project[]
  version     Int      @default(1)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyName])
  @@index([shortCode])
}

// Zentraler Artikelstamm (Kernfelder). Preis/MwSt bleiben in kontor, Lieferanten-/
// Hersteller-Nr. in ProjectEye lokal. `number` = zentrale, fortlaufende Stammnummer,
// wird ausschließlich von Nexus beim POST vergeben (höchste + 1, transaktional).
model Product {
  id          String    @id @default(cuid())
  number      Int       @unique
  name        String    @default("")
  description String    @default("")
  unit        String    @default("Stk.")
  category    String    @default("")
  active      Boolean   @default(true)
  origin      String    @default("")
  price       Float     @default(0)
  imageUrl    String    @default("") @db.Text
  links       String    @default("") @db.Text
  version     Int       @default(1)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([updatedAt])
}

model CustomerNumber {
  id           String @id @default(cuid())
  customerId   String
  orgId        String
  number       String
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([customerId, orgId])
  @@unique([orgId, number])
}

model CustomerContact {
  id         String @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  role       String @default("")
  email      String @default("")
  phone      String @default("")
  mobile     String @default("")
}

// ---- Projekt (geschäftlich) ----
model Project {
  id           String  @id @default(cuid())
  name         String
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  color        String  @default("#7c3cc0")
  hourlyRate   Float   @default(0)
  status       String  @default("offen")
  teamLeaderId String?
  archived     Boolean @default(false)
  version      Int      @default(1)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([customerId])
  @@index([name])
}

// ---- Aufgabe (zentral; alle Apps arbeiten gemeinsam daran) ----
model Task {
  id          String  @id @default(cuid())
  title       String
  description String  @default("") @db.Text
  status      String  @default("offen")    // offen | laeuft | erledigt
  priority    String  @default("normal")   // niedrig | normal | hoch
  projectId   String?                       // zentrale Projekt-ID
  assigneeId  String?                       // zuständiger Mitarbeiter (Employee-ID)
  dueDate     DateTime?
  done        Boolean @default(false)
  appKey      String  @default("")          // optional: welche App die Aufgabe erstellt hat
  version     Int      @default(1)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

// ---- Mitarbeiter (HR-Kern; Lohn bleibt in clocker) ----
model Employee {
  id             String  @id @default(cuid())
  name           String
  email          String  @default("")
  employeeNumber String  @default("")
  color          String  @default("#7c3cc0")
  identityId     String?
  archived       Boolean @default(false)
  version        Int      @default(1)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([name])
}

// ---- Zentrale Identität (Login für ALLE Apps) ----
model Identity {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  name         String
  globalRole   String @default("user")
  employeeId   String?
  appAccess    IdentityAppAccess[]
  version      Int      @default(1)
  origin       String  @default("central")
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model IdentityAppAccess {
  id          String  @id @default(cuid())
  identityId  String
  appKey      String
  allowed     Boolean @default(true)
  role        String  @default("user")
  rights      String  @default("{}")
  localUserId String?
  syncedAt    DateTime?
  identity    Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@unique([identityId, appKey])
  @@index([appKey])
}

// ---- Undo/Redo: Revisionen jeder Schreiboperation ----
model Revision {
  id         String  @id @default(cuid())
  txId       String
  entity     String
  entityId   String
  action     String
  before     String? @db.Text
  after      String? @db.Text
  identityId String
  appKey     String
  undone     Boolean @default(false)
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([txId])
  @@index([createdAt])
}

// ---- Locking: optionaler pessimistischer Edit-Lock ----
model EditLock {
  id         String  @id @default(cuid())
  entity     String
  entityId   String
  identityId String
  identityName String @default("")
  appKey     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@unique([entity, entityId])
}

// ---- Arbeitsvertrag (HR-Dokument; Mitarbeiterdaten werden zum Vertragszeitpunkt eingefroren) ----
model EmploymentContract {
  id              String   @id @default(cuid())
  title           String   @default("")                 // z. B. "Arbeitsvertrag – Max Mustermann"
  employeeId      String   @default("")                 // Referenz auf Employee (lose ID, wie Task.assigneeId)
  // Vertragsparteien (denormalisiert – Dokument bleibt eigenständig)
  employeeName    String   @default("")
  employeeAddress String   @default("")                 // Straße, PLZ Ort (mehrzeilig erlaubt)
  employeeBirth   String   @default("")                 // Geburtsdatum (Freitext, z. B. "01.01.1990")
  // Vertragsdaten
  jobTitle        String   @default("")                 // Tätigkeit / Position
  startDate       DateTime?                              // Eintrittsdatum
  contractType    String   @default("unbefristet")      // unbefristet | befristet
  endDate         DateTime?                              // bei Befristung
  probationMonths Int      @default(6)                   // Probezeit in Monaten (0 = keine)
  weeklyHours     Float    @default(40)                  // Wochenarbeitszeit
  salary          Float    @default(0)                   // Bruttoentgelt
  salaryPeriod    String   @default("monatlich")         // monatlich | stündlich
  vacationDays    Int      @default(30)                  // Urlaubstage/Jahr
  noticeText      String   @default("gesetzliche Fristen") // Kündigungsfrist
  workplace       String   @default("Cloppenburg")       // Arbeitsort
  additionalTerms String   @default("") @db.Text          // freie Zusatzvereinbarungen
  signCity        String   @default("Cloppenburg")        // Unterschriftsort
  signDate        DateTime?                               // Datum der Unterzeichnung
  status          String   @default("entwurf")            // entwurf | aktiv | beendet
  archived        Boolean  @default(false)
  version         Int      @default(1)
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
}
